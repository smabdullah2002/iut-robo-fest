# Copy this file to .env and adjust values as needed.
# No secrets/API keys are required to run this frontend.

# "live"       -> devices are fetched from the shared backend built by the team (default for the local backend).
# "simulation" -> devices are generated & animated entirely in the browser.
VITE_DATA_SOURCE=live

# Only used when VITE_DATA_SOURCE=live. Base URL of the shared backend API.
# Example: http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000

# Only used when VITE_DATA_SOURCE=live. Polling interval in milliseconds for fetching live state.
VITE_POLL_INTERVAL_MS=3000

# Office hours used by the Active Alerts panel (24h format, local time).
VITE_OFFICE_HOURS_START=9
VITE_OFFICE_HOURS_END=17

# Continuous "left on" threshold before a room-level alert fires, in hours.
VITE_CONTINUOUS_ON_ALERT_HOURS=2
